rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — can read/write own doc; admin can read all
    match /users/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "rezig@admin.np"
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Creators — anyone authenticated can create; admin can update status
    match /creators/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Offers — clients create; everyone authenticated can read; admin updates
    match /offers/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Bids — creators create; everyone authenticated reads; admin updates
    match /bids/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
