rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public stats — readable by anyone (visitors too), writable only by auth users
    match /public/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users — readable by authenticated users (needed for admin + counts)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Creators
    match /creators/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Offers
    match /offers/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Bids
    match /bids/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
