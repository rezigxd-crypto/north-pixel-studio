rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public stats — readable by anyone (visitors too), writable only by auth users
    match /public/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users — any authenticated user can read (admin needs to LIST clients);
    // each user can only write their own document.
    // NOTE: this rule covers BOTH `get` (single doc) AND `list` (collection query).
    // If admin sees no clients, redeploy these rules:
    //   firebase deploy --only firestore:rules
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Creators (freelancer applications)
    match /creators/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Offers (client projects)
    match /offers/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Bids (creator offers on projects)
    match /bids/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // MovieCollab quest applications — anyone can apply (logged in or visitor),
    // but only authed users can read their list (admin will moderate).
    match /questApplications/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Bundle subscriptions — B2B / B2G monthly retainers.
    //   • create: any authed user (the requesting client).
    //   • read/list: any authed user — the admin needs to list them all,
    //     and clients filter their own list with a where(clientUid==me).
    //   • update: any authed user (admin updates status; client may update
    //     their own pre-active notes). Tightening to admin-only would
    //     require a custom claim which we don't use; rules are kept
    //     consistent with the rest of the project.
    match /bundleSubscriptions/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;

      // Deliverables under each subscription. Same authed-only model as
      // the parent — admin manages, client reads.
      match /deliverables/{delivId} {
        allow create, read, update, delete: if request.auth != null;
      }
    }

    // Task invitations — admin invites a freelancer to a private task.
    //   • create: any authed user. fromAdminUid is set client-side to
    //     the actor's own uid.
    //   • read/list: any authed user (creator filters with where(toCreatorUid==me),
    //     admin filters with where(fromAdminUid==me)).
    //   • update: any authed user (creator accepts/declines, admin completes).
    match /taskInvitations/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Notifications — per-user feed.
    //   • create: any authed user can write (so a creator placing a bid
    //     can drop a `new_bid` notification on the project owner). The
    //     recipientUid is set client-side, but the creator is also forced
    //     to mark `read: false` at create time, so they can't pre-read or
    //     spoof the dot.
    //   • read/list: only the recipient (or admin tooling, which is run
    //     while logged in as the recipient anyway).
    //   • update: only the recipient, and only to flip `read` to true.
    match /notifications/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.recipientUid is string
                    && request.resource.data.recipientUid.size() > 0
                    && request.resource.data.read == false;
      allow read: if request.auth != null
                  && resource.data.recipientUid == request.auth.uid;
      // The only legitimate mutation is flipping `read` from false to true.
      // Pin every other field so the recipient can't rewrite history (meta,
      // link, createdAt) or reset the dot back to unread.
      allow update: if request.auth != null
                    && resource.data.recipientUid == request.auth.uid
                    && request.resource.data.recipientUid == resource.data.recipientUid
                    && request.resource.data.type == resource.data.type
                    && request.resource.data.meta == resource.data.meta
                    && request.resource.data.link == resource.data.link
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.read == true;
      allow delete: if request.auth != null
                    && resource.data.recipientUid == request.auth.uid;
    }
  }
}
