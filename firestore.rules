rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin identity — verified by the auth token's email claim. Mirrors the
    // pattern already used by /publicConfig and /clientTags below.
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == "rezig@admin.np";
    }

    // Public stats — readable by anyone (visitors too), writable only by auth users
    match /public/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users — any authenticated user can read (admin needs to LIST clients);
    // each user can only write their own document.
    // NOTE: this rule covers BOTH `get` (single doc) AND `list` (collection query).
    // If admin sees no clients, redeploy these rules:
    //   firebase deploy --only firestore:rules
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Creators (freelancer applications = the admin moderation queue).
    //   • create: any authed user MAY apply, but the application MUST start
    //     `pending`. This blocks a creator from self-approving at creation
    //     time by writing `status: "approved"` directly.
    //   • read: any authed user (admin lists the queue; portals resolve status).
    //   • update: ADMIN ONLY. Approval / rejection is an admin-only moderation
    //     action (setCreatorStatus). No legitimate creator-side write exists —
    //     profile edits live on the /users/{uid} doc. This is what enforces the
    //     "human review before anything goes live" trust guarantee.
    match /creators/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.status == "pending";
      allow read: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Offers (client projects).
    //   • create: any authed user, but the offer MUST start `pending_admin`
    //     so nobody can post a project that is already `open`/`assigned` and
    //     skip the admin review gate.
    //   • read: any authed user.
    //   • update: any authed user. NOTE (phase-2 hardening): updates remain
    //     open because the client-side auto-close sweeper (checkAutoCloseOffers
    //     → acceptBid) runs on ordinary users' portal mounts and legitimately
    //     writes offers they don't own (status→assigned, acceptedBidId, cached
    //     contacts). Locking this to owner/admin requires first moving the
    //     sweeper to an admin-only / server context. Tracked separately.
    match /offers/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.status == "pending_admin";
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Bids (creator offers on projects).
    //   • create: any authed user, but the bid MUST start `pending` AND be
    //     bound to the creator's own uid (creatorId == auth.uid). This stops a
    //     user from planting a pre-`accepted` bid or bidding as someone else.
    //   • read: any authed user.
    //   • update: any authed user. NOTE (phase-2 hardening): bids are written
    //     by three parties — the owning creator (submitDeliverable), the owning
    //     client (acceptDelivery / requestRevisions), and admin (acceptBid,
    //     releasePayment, plus rejecting the losing bids). The auto-close
    //     sweeper also rejects losing bids from a non-owner context. Safe
    //     lock-down needs field-pinned, per-transition rules + the sweeper move
    //     above. Tracked separately.
    match /bids/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.status == "pending"
                    && request.resource.data.creatorId == request.auth.uid;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // MovieCollab quest applications — anyone can apply (logged in or visitor),
    // but only authed users can read their list (admin will moderate).
    match /questApplications/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Public config — small key/value store used to publish things like the
    // admin UID so other clients can route notifications to the admin.
    //   • read: any authed user.
    //   • write: ONLY the admin (verified by email claim). Without this,
    //     any authed user could overwrite /publicConfig/admin and hijack
    //     bundle_request_new notification routing.
    match /publicConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == "rezig@admin.np";
    }

    // Client tags — admin-only B2B / B2G classification of client accounts.
    //   • read/write: ONLY the admin (verified by email claim). The data is
    //     internal admin metadata and should never leak to clients themselves.
    match /clientTags/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == "rezig@admin.np";
    }

    // Bundle subscriptions — B2B / B2G monthly retainers.
    //   • create: any authed user (the requesting client).
    //   • read/list: any authed user — the admin needs to list them all,
    //     and clients filter their own list with a where(clientUid==me).
    //   • update: any authed user (admin updates status; client may update
    //     their own pre-active notes). Tightening to admin-only would
    //     require a custom claim which we don't use; rules are kept
    //     consistent with the rest of the project.
    match /bundleSubscriptions/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;

      // Deliverables under each subscription. Same authed-only model as
      // the parent — admin manages, client reads.
      match /deliverables/{delivId} {
        allow create, read, update, delete: if request.auth != null;
      }
    }

    // Task invitations — admin invites a freelancer to a private task.
    //   • create: any authed user. fromAdminUid is set client-side to
    //     the actor's own uid.
    //   • read/list: any authed user (creator filters with where(toCreatorUid==me),
    //     admin filters with where(fromAdminUid==me)).
    //   • update: any authed user (creator accepts/declines, admin completes).
    match /taskInvitations/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Notifications — per-user feed.
    //   • create: any authed user can write (so a creator placing a bid
    //     can drop a `new_bid` notification on the project owner). The
    //     recipientUid is set client-side, but the creator is also forced
    //     to mark `read: false` at create time, so they can't pre-read or
    //     spoof the dot.
    //   • read/list: only the recipient (or admin tooling, which is run
    //     while logged in as the recipient anyway).
    //   • update: only the recipient, and only to flip `read` to true.
    match /notifications/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.recipientUid is string
                    && request.resource.data.recipientUid.size() > 0
                    && request.resource.data.read == false;
      allow read: if request.auth != null
                  && resource.data.recipientUid == request.auth.uid;
      // The only legitimate mutation is flipping `read` from false to true.
      // Pin every other field so the recipient can't rewrite history (meta,
      // link, createdAt) or reset the dot back to unread.
      allow update: if request.auth != null
                    && resource.data.recipientUid == request.auth.uid
                    && request.resource.data.recipientUid == resource.data.recipientUid
                    && request.resource.data.type == resource.data.type
                    && request.resource.data.meta == resource.data.meta
                    && request.resource.data.link == resource.data.link
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.read == true;
      allow delete: if request.auth != null
                    && resource.data.recipientUid == request.auth.uid;
    }
  }
}
