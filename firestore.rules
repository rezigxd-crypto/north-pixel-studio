rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public stats — readable by anyone (visitors too), writable only by auth users
    match /public/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users — any authenticated user can read (admin needs to LIST clients
    // along with phone numbers + Baridi Mob accounts); each user can only
    // write their OWN document.
    //
    // ⚠️ IMPORTANT: `read` covers BOTH `get` (single doc) AND `list`
    // (collection query). If clients still don't appear in the admin
    // dashboard, redeploy these rules in your terminal:
    //
    //     firebase deploy --only firestore:rules
    //
    // Until rules are redeployed, the admin dashboard automatically falls
    // back to deriving clients from the /offers collection so they still
    // show up — they just won't include phone/Baridi Mob until rules go live.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Creators (freelancer applications)
    match /creators/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Offers (client projects)
    match /offers/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Bids (creator offers on projects)
    match /bids/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
